{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "lint",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "${workspaceFolder}/scripts/lint.ps1"],
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": ["build", "BalanceBoard.sln", "-c", "Release", "-warnaserror"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run app",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/BalanceBoard.App/BalanceBoard.App.csproj",
        "-c",
        "Release",
        "--",
        "--dev"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
