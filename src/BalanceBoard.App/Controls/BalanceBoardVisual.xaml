<UserControl x:Class="BalanceBoard.App.Controls.BalanceBoardVisual"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="220" MinWidth="220">
    <Border Background="{DynamicResource Brush.BoardSurface}"
            BorderBrush="{DynamicResource Brush.BoardBorder}"
            BorderThickness="1"
            CornerRadius="{StaticResource Radius.Card}">
        <Canvas x:Name="BoardCanvas" Margin="24">
            <Ellipse x:Name="TopLeftDot" Width="14" Height="14" Fill="{DynamicResource Brush.BoardDot}"/>
            <Ellipse x:Name="TopRightDot" Width="14" Height="14" Fill="{DynamicResource Brush.BoardDot}"/>
            <Ellipse x:Name="BottomLeftDot" Width="14" Height="14" Fill="{DynamicResource Brush.BoardDot}"/>
            <Ellipse x:Name="BottomRightDot" Width="14" Height="14" Fill="{DynamicResource Brush.BoardDot}"/>
            <Ellipse x:Name="CenterDot" Width="20" Height="20"
                     Fill="{DynamicResource Brush.BoardCenter}"
                     Stroke="{DynamicResource Brush.Foreground}" StrokeThickness="2"/>
        </Canvas>
    </Border>
</UserControl>
