<UserControl x:Class="BalanceBoard.App.Controls.ActionBindingRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,0,0,6">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="108"/>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="SlotLabel" Grid.Column="0" Style="{DynamicResource Text.Body}"
                   VerticalAlignment="Center" FontSize="13"/>

        <ComboBox x:Name="KindCombo" Grid.Column="1" Margin="0,0,8,0"
                  VerticalAlignment="Center" SelectionChanged="KindCombo_SelectionChanged"/>

        <Grid Grid.Column="2" VerticalAlignment="Center">
            <Button x:Name="KeyCaptureButton" Style="{StaticResource Button.Secondary}"
                    Content="Press a key…" Click="KeyCaptureButton_Click"
                    PreviewKeyDown="KeyCaptureButton_PreviewKeyDown" Focusable="True"
                    Visibility="Collapsed" HorizontalAlignment="Stretch" Padding="8,4" Margin="0"/>
            <ComboBox x:Name="MouseButtonCombo" Visibility="Collapsed"
                      SelectionChanged="Value_Changed"/>
            <StackPanel x:Name="MovePanel" Orientation="Horizontal" Visibility="Collapsed">
                <Slider x:Name="MoveAmountSlider" Minimum="-40" Maximum="40" Width="120"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="MoveAmount_Changed"/>
                <TextBlock x:Name="MoveAmountLabel" Style="{DynamicResource Text.Subtitle}"
                           VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="48"/>
            </StackPanel>
            <TextBlock x:Name="NoneLabel" Text="—" Style="{DynamicResource Text.Subtitle}"
                       VerticalAlignment="Center" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
