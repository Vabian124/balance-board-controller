<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Background" Color="#F4F6FA"/>
    <SolidColorBrush x:Key="Brush.Foreground" Color="#111827"/>
    <SolidColorBrush x:Key="Brush.Muted" Color="#5B6472"/>
    <SolidColorBrush x:Key="Brush.Card" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.CardBorder" Color="#D7DEE8"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="#2563EB"/>
    <SolidColorBrush x:Key="Brush.AccentText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Hover" Color="#E8EDF5"/>
    <SolidColorBrush x:Key="Brush.Pressed" Color="#D0D8E6"/>

    <Color x:Key="Color.Success">#16A34A</Color>
    <Color x:Key="Color.Warning">#D97706</Color>
    <Color x:Key="Color.Danger">#DC2626</Color>
    <Color x:Key="Color.Info">#2563EB</Color>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}"/>

    <SolidColorBrush x:Key="Brush.BoardSurface" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Brush.BoardBorder" Color="#94A3B8"/>
    <SolidColorBrush x:Key="Brush.BoardPadTL" Color="#4A90D9"/>
    <SolidColorBrush x:Key="Brush.BoardPadTR" Color="#F5C542"/>
    <SolidColorBrush x:Key="Brush.BoardPadBL" Color="#5CB85C"/>
    <SolidColorBrush x:Key="Brush.BoardPadBR" Color="#E85D5D"/>
    <SolidColorBrush x:Key="Brush.BoardCenter" Color="#E11D48"/>
    <SolidColorBrush x:Key="Brush.BoardCenterStroke" Color="#FFFFFF"/>

    <FontFamily x:Key="Font.UI">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas, monospace</FontFamily>

    <CornerRadius x:Key="Radius.Card">10</CornerRadius>
    <CornerRadius x:Key="Radius.Button">6</CornerRadius>
    <Thickness x:Key="Thickness.Page">20</Thickness>
    <Thickness x:Key="Thickness.Card">16</Thickness>

</ResourceDictionary>
