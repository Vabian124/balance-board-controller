<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Background" Color="#0F1419"/>
    <SolidColorBrush x:Key="Brush.Foreground" Color="#E8EDF5"/>
    <SolidColorBrush x:Key="Brush.Muted" Color="#9AA6B8"/>
    <SolidColorBrush x:Key="Brush.Card" Color="#1A2230"/>
    <SolidColorBrush x:Key="Brush.CardBorder" Color="#2D3A4D"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="#3B82F6"/>
    <SolidColorBrush x:Key="Brush.AccentText" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Brush.Hover" Color="#243044"/>
    <SolidColorBrush x:Key="Brush.Pressed" Color="#334155"/>

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#243044"/>
    <SolidColorBrush x:Key="Brush.InputForeground" Color="#E8EDF5"/>
    <SolidColorBrush x:Key="Brush.DropdownBackground" Color="#1A2230"/>
    <SolidColorBrush x:Key="Brush.DropdownForeground" Color="#E8EDF5"/>
    <SolidColorBrush x:Key="Brush.DropdownHighlight" Color="#334155"/>
    <SolidColorBrush x:Key="Brush.DropdownHighlightText" Color="#F8FAFC"/>

    <Color x:Key="Color.Success">#22C55E</Color>
    <Color x:Key="Color.Warning">#F59E0B</Color>
    <Color x:Key="Color.Danger">#F87171</Color>
    <Color x:Key="Color.Info">#60A5FA</Color>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource Color.Info}"/>

    <Color x:Key="Color.Minecraft">#22C55E</Color>
    <SolidColorBrush x:Key="Brush.Minecraft" Color="{StaticResource Color.Minecraft}"/>
    <SolidColorBrush x:Key="Brush.JumpActive" Color="{StaticResource Color.Success}"/>

    <SolidColorBrush x:Key="Brush.BoardSurface" Color="#1E293B"/>
    <SolidColorBrush x:Key="Brush.BoardBorder" Color="#64748B"/>
    <SolidColorBrush x:Key="Brush.BoardPadTL" Color="#60A5FA"/>
    <SolidColorBrush x:Key="Brush.BoardPadTR" Color="#FCD34D"/>
    <SolidColorBrush x:Key="Brush.BoardPadBL" Color="#4ADE80"/>
    <SolidColorBrush x:Key="Brush.BoardPadBR" Color="#F87171"/>
    <SolidColorBrush x:Key="Brush.BoardCenter" Color="#F472B6"/>
    <SolidColorBrush x:Key="Brush.BoardCenterStroke" Color="#0F1419"/>

    <FontFamily x:Key="Font.UI">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas, monospace</FontFamily>

    <CornerRadius x:Key="Radius.Card">10</CornerRadius>
    <CornerRadius x:Key="Radius.Button">6</CornerRadius>
    <Thickness x:Key="Thickness.Page">20</Thickness>
    <Thickness x:Key="Thickness.Card">16</Thickness>

</ResourceDictionary>
