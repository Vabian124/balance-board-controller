<Window x:Class="BalanceBoard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BalanceBoard.App.Controls"
        Title="Balance Board Controller"
        Icon="Assets/balance-board-icon.ico"
        Height="780" Width="1100"
        MinHeight="640" MinWidth="900"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{StaticResource Font.UI}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid Margin="{StaticResource Thickness.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Balance Board Controller" Style="{StaticResource Text.Title}"/>
                <TextBlock x:Name="StatusText" Style="{StaticResource Text.Subtitle}" Margin="0,4,0,8"
                           Text="Ready — click Connect when you're set."/>
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="ConnectionChip" Style="{StaticResource StatusChip}" Margin="0,0,8,0">
                        <TextBlock x:Name="ConnectionChipText" Text="Board: offline" FontSize="12"/>
                    </Border>
                    <Border x:Name="VJoyChip" Style="{StaticResource StatusChip}">
                        <TextBlock x:Name="VJoyChipText" Text="vJoy: …" FontSize="12"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="ConnectButton" Content="Connect" Style="{StaticResource Button.Primary}" Click="ConnectButton_Click"/>
                <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource Button.Secondary}" Click="CancelButton_Click" Visibility="Collapsed"/>
                <Button x:Name="DisconnectButton" Content="Disconnect" Style="{StaticResource Button.Secondary}" Click="DisconnectButton_Click"/>
                <Button Content="Exit" Style="{StaticResource Button.Ghost}" Click="ExitButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Live balance -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="LIVE BALANCE" Style="{StaticResource Text.Section}"/>
                        <TextBlock x:Name="DirectionText" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Foreground}" Margin="0,0,0,4"
                                   Text="Connect your board to begin"/>
                        <TextBlock x:Name="ActiveActionsText" Style="{StaticResource Text.Subtitle}"/>
                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Tare" Style="{StaticResource Button.Primary}" Click="Tare_Click"/>
                            <Button Content="Set center" Style="{StaticResource Button.Secondary}" Click="SetCenter_Click"/>
                            <Button Content="Reset center" Style="{StaticResource Button.Ghost}" Click="ResetCenter_Click"/>
                        </WrapPanel>
                    </StackPanel>

                    <controls:BalanceBoardVisual x:Name="BoardVisual" Grid.Row="1" Margin="0,8,0,8" MinHeight="260"/>

                    <StackPanel Grid.Row="2">
                        <TextBlock x:Name="WeightText" Style="{StaticResource Text.Body}" FontWeight="SemiBold"
                                   Text="Weight: — kg"/>
                        <TextBlock x:Name="BalanceText" Style="{StaticResource Text.Subtitle}" Margin="0,4,0,0"
                                   Text="Balance: — / —"/>
                        <TextBlock x:Name="SensorText" Style="{StaticResource Text.Mono}" Margin="0,8,0,0"
                                   Text="Sensors: connect to see corner loads"/>
                        <TextBlock x:Name="BoardButtonText" Style="{StaticResource Text.Subtitle}" Margin="0,4,0,0"
                                   Text="Board button: —"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Settings -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="PROFILE" Style="{StaticResource Text.Section}"/>
                            <ComboBox x:Name="ProfileCombo" Margin="0,0,0,8" SelectionChanged="ProfileCombo_SelectionChanged"/>
                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                <Button x:Name="GamePresetButton" Content="Games" Style="{StaticResource Button.Secondary}" Margin="0,0,4,4" Click="GamePreset_Click"/>
                                <Button x:Name="DesktopPresetButton" Content="Desktop" Style="{StaticResource Button.Secondary}" Margin="0,0,0,4" Click="KeyboardPreset_Click"/>
                                <Button x:Name="PedalPresetButton" Content="Pedals" Style="{StaticResource Button.Secondary}" Margin="0,0,4,0" Click="PedalPreset_Click"/>
                                <Button x:Name="MousePresetButton" Content="Mouse" Style="{StaticResource Button.Secondary}" Click="MousePreset_Click"/>
                            </UniformGrid>
                            <CheckBox x:Name="AutoConnectCheck" Content="Connect automatically on launch"
                                      Checked="SettingChanged" Unchecked="SettingChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Theme" VerticalAlignment="Center" Style="{StaticResource Text.Subtitle}" Margin="0,0,8,0"/>
                                <ComboBox x:Name="ThemeCombo" Width="140" SelectionChanged="ThemeCombo_SelectionChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Expander Header="Keyboard &amp; mouse controls" IsExpanded="False">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource Text.Subtitle}" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Text="Map lean directions to keys or mouse actions. Disable vJoy keyboard block to use these while gaming."/>
                            <controls:ActionBindingRow x:Name="BindLeft" SlotDisplayName="Left" BindingChanged="ActionBinding_Changed"/>
                            <controls:ActionBindingRow x:Name="BindRight" SlotDisplayName="Right" BindingChanged="ActionBinding_Changed"/>
                            <controls:ActionBindingRow x:Name="BindForward" SlotDisplayName="Forward" BindingChanged="ActionBinding_Changed"/>
                            <controls:ActionBindingRow x:Name="BindBackward" SlotDisplayName="Backward" BindingChanged="ActionBinding_Changed"/>
                            <controls:ActionBindingRow x:Name="BindJump" SlotDisplayName="Jump" BindingChanged="ActionBinding_Changed"/>
                            <controls:ActionBindingRow x:Name="BindModifier" SlotDisplayName="Modifier" BindingChanged="ActionBinding_Changed"/>
                            <controls:ActionBindingRow x:Name="BindDiagonalLeft" SlotDisplayName="Diagonal left" BindingChanged="ActionBinding_Changed"/>
                            <controls:ActionBindingRow x:Name="BindDiagonalRight" SlotDisplayName="Diagonal right" BindingChanged="ActionBinding_Changed"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Controller output (vJoy)" IsExpanded="True">
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox x:Name="EnableVJoyCheck" Content="Use virtual game controller" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            <CheckBox x:Name="SendCgCheck" Content="Balance → X/Y axes" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            <CheckBox x:Name="SendSensorsCheck" Content="Load sensors → Z/RX/RY/RZ" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            <CheckBox x:Name="DisableActionsCheck" Content="Disable keyboard/mouse output" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="vJoy device" VerticalAlignment="Center" Style="{StaticResource Text.Subtitle}" Margin="0,0,8,0"/>
                                <ComboBox x:Name="VJoyDeviceCombo" Width="64" SelectionChanged="SettingChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Calibration">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Style="{StaticResource Text.Subtitle}" TextWrapping="Wrap"
                                       Text="Tare zeros the board while you are off it. Set center while standing in your neutral pose."/>
                            <CheckBox x:Name="AutoTareCheck" Content="Auto-tare when connected" Margin="0,8,0,0" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Sensitivity &amp; triggers" IsExpanded="True">
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox x:Name="SimpleSensitivityCheck" Content="Simple presets (kids / accessibility)"
                                      IsChecked="True" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            <WrapPanel x:Name="SimpleSensitivityPanel" Margin="0,8,0,0">
                                <Button x:Name="SensitivityLowButton" Content="Low" Style="{StaticResource Button.Secondary}" Click="SensitivityLow_Click"/>
                                <Button x:Name="SensitivityMediumButton" Content="Medium" Style="{StaticResource Button.Secondary}" Click="SensitivityMedium_Click"/>
                                <Button x:Name="SensitivityHighButton" Content="High" Style="{StaticResource Button.Secondary}" Click="SensitivityHigh_Click"/>
                                <Button x:Name="SensitivityHighlyButton" Content="Highly sensitive" Style="{StaticResource Button.Secondary}" Click="SensitivityHighly_Click"/>
                            </WrapPanel>
                            <StackPanel x:Name="AdvancedSensitivityPanel" Margin="0,8,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="TriggerLeftRightLabel" Style="{StaticResource Text.Subtitle}"/>
                                <Slider x:Name="TriggerLeftRightSlider" Minimum="1" Maximum="30" Value="8" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                <TextBlock x:Name="TriggerForwardBackwardLabel" Style="{StaticResource Text.Subtitle}"/>
                                <Slider x:Name="TriggerForwardBackwardSlider" Minimum="1" Maximum="30" Value="9" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                <TextBlock x:Name="DeadzoneLabel" Style="{StaticResource Text.Subtitle}" Margin="0,8,0,0"/>
                                <Slider x:Name="DeadzoneSlider" Minimum="0" Maximum="20" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                <TextBlock x:Name="SensitivityLabel" Style="{StaticResource Text.Subtitle}"/>
                                <Slider x:Name="SensitivitySlider" Minimum="0.5" Maximum="3" Value="1" TickFrequency="0.1" ValueChanged="SettingChanged"/>
                                <TextBlock x:Name="JumpThresholdLabel" Style="{StaticResource Text.Subtitle}" Margin="0,8,0,0"/>
                                <Slider x:Name="JumpThresholdSlider" Minimum="0.2" Maximum="5" Value="1" TickFrequency="0.1" ValueChanged="SettingChanged"/>
                                <TextBlock x:Name="JumpHoldLabel" Style="{StaticResource Text.Subtitle}"/>
                                <Slider x:Name="JumpHoldSlider" Minimum="0.5" Maximum="4" Value="2" TickFrequency="0.1" ValueChanged="SettingChanged"/>
                            </StackPanel>
                            <CheckBox x:Name="InvertXCheck" Content="Invert X" Margin="0,8,0,0" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            <CheckBox x:Name="InvertYCheck" Content="Invert Y" Checked="SettingChanged" Unchecked="SettingChanged"/>
                        </StackPanel>
                    </Expander>

                    <Expander Header="Diagnostics">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock x:Name="HealthSummaryText" Style="{StaticResource Text.Subtitle}" Margin="0,0,0,8"
                                       Text="Run a health check to verify vJoy and Bluetooth."/>
                            <TextBlock x:Name="VJoyStatusText" Style="{StaticResource Text.Mono}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="VJoyAxesText" Style="{StaticResource Text.Mono}" Margin="0,0,0,8"/>
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Health check" Style="{StaticResource Button.Primary}" Click="RunHealthCheckButton_Click"/>
                                <Button Content="Copy report" Style="{StaticResource Button.Secondary}" Click="CopyReportButton_Click"/>
                                <Button Content="Open logs" Style="{StaticResource Button.Secondary}" Click="OpenLogFolderButton_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Log strip -->
        <Expander Grid.Row="2" Header="Session log" Margin="0,12,0,0" IsExpanded="False">
            <Grid Height="140" Margin="0,8,0,0">
                <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                         FontFamily="{StaticResource Font.Mono}" FontSize="12"
                         Background="{DynamicResource Brush.Card}"
                         Foreground="{DynamicResource Brush.Foreground}"
                         BorderBrush="{DynamicResource Brush.CardBorder}" BorderThickness="1"/>
                <Button Content="Clear view" Style="{StaticResource Button.Ghost}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="8" Click="ClearLogViewButton_Click"/>
            </Grid>
        </Expander>
    </Grid>
</Window>
