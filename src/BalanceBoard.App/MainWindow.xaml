<Window x:Class="BalanceBoard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BalanceBoard.App.Controls"
        Title="Balance Board Controller"
        Icon="Assets/balance-board-icon.ico"
        Height="780" Width="1000"
        MinHeight="600" MinWidth="860"
        Background="{DynamicResource Brush.Background}"
        FontFamily="{StaticResource Font.UI}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid Margin="{StaticResource Thickness.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <TextBlock Grid.Row="0" Text="Balance Board Controller" Style="{DynamicResource Text.Title}" Margin="0,0,0,8"/>

        <!-- Tabbed content -->
        <TabControl x:Name="MainTabControl" Grid.Row="1" Style="{StaticResource TabControl.Main}">
            <!-- Dashboard -->
            <TabItem Header="Dashboard" Style="{StaticResource TabItem.Main}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Connection strip (compact) -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel LastChildFill="True" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                <Border x:Name="ConnectionChip" Style="{StaticResource StatusChip}" Margin="8,0,8,0">
                                    <TextBlock x:Name="ConnectionChipText" Text="Board: offline" FontSize="11"
                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                </Border>
                                <Border x:Name="VJoyChip" Style="{StaticResource StatusChip}">
                                    <TextBlock x:Name="VJoyChipText" Text="vJoy: …" FontSize="11"
                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="StatusText" Style="{DynamicResource Text.Subtitle}" FontSize="13"
                                       TextTrimming="CharacterEllipsis"
                                       Text="Ready — click Connect when you're set."/>
                        </DockPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="ShowLogButton" Content="Show log" MinHeight="32" Style="{StaticResource Button.Ghost}"
                                    Click="ShowLogButton_Click" Visibility="Collapsed"
                                    AutomationProperties.Name="Toggle session log"/>
                            <Button x:Name="ConnectButton" Content="Connect" MinHeight="44" Style="{StaticResource Button.Primary}" Click="ConnectButton_Click"
                                    AutomationProperties.Name="Connect to balance board"
                                    AutomationProperties.HelpText="Pair and connect your Wii Balance Board over Bluetooth."/>
                            <Button x:Name="CancelButton" Content="Cancel" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="CancelButton_Click" Visibility="Collapsed"/>
                            <Button x:Name="DisconnectButton" Content="Disconnect" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="DisconnectButton_Click"/>
                            <Button x:Name="ExitButton" Content="Exit" MinHeight="44" Style="{StaticResource Button.Ghost}" Click="ExitButton_Click"/>
                        </StackPanel>
                    </Grid>

                    <Border x:Name="PhysicalTestPanel" Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,8" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="PHYSICAL TEST MODE" Style="{DynamicResource Text.Section}"/>
                            <TextBlock x:Name="PhysicalTestScenarioText" Style="{DynamicResource Text.Subtitle}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            <TextBlock x:Name="PhysicalTestArtifactsText" Style="{DynamicResource Text.Mono}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <Border Margin="0,10,0,0" Padding="12" CornerRadius="12"
                                    Background="{DynamicResource Brush.Card}"
                                    BorderBrush="{DynamicResource Brush.CardBorder}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="PhysicalTestStepTitleText" FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                    <TextBlock x:Name="PhysicalTestStepInstructionsText" Style="{DynamicResource Text.Body}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PhysicalTestExpectedSignalText" Style="{DynamicResource Text.Subtitle}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="PhysicalTestProgressText" Style="{DynamicResource Text.Mono}" Margin="0,8,0,0"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button x:Name="PhysicalTestPassButton" Content="Pass step" MinHeight="36" Style="{StaticResource Button.Primary}" Click="PhysicalTestPassButton_Click"/>
                                        <Button x:Name="PhysicalTestFailButton" Content="Fail step" MinHeight="36" Style="{StaticResource Button.Secondary}" Click="PhysicalTestFailButton_Click"/>
                                        <Button x:Name="PhysicalTestSkipButton" Content="Skip step" MinHeight="36" Style="{StaticResource Button.Ghost}" Click="PhysicalTestSkipButton_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Live balance (visual-first) -->
                    <Border x:Name="BalancePanel" Grid.Row="2" Style="{StaticResource Card}" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="DirectionText" FontSize="22" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.Foreground}"
                                               Text="Connect your board to begin"
                                               AutomationProperties.Name="Movement and jump feedback"
                                               AutomationProperties.LiveSetting="Assertive"/>
                                    <TextBlock x:Name="ActiveActionsText" Style="{DynamicResource Text.Subtitle}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <WrapPanel x:Name="CalibrationButtonsPanel" Grid.Column="1" VerticalAlignment="Center">
                                    <Button x:Name="TareButton" Content="Tare" MinHeight="44" Style="{StaticResource Button.Primary}" Click="Tare_Click"/>
                                    <Button x:Name="SetCenterButton" Content="Set center" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="SetCenter_Click"/>
                                    <Button x:Name="ResetCenterButton" Content="Reset center" MinHeight="44" Style="{StaticResource Button.Ghost}" Click="ResetCenter_Click"/>
                                </WrapPanel>
                            </Grid>

                            <controls:BalanceBoardVisual x:Name="BoardVisual" Grid.Row="1" Margin="0,4,0,4" MinHeight="360" VerticalAlignment="Stretch"/>

                            <StackPanel Grid.Row="2" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="WeightText" Style="{DynamicResource Text.Body}" FontWeight="SemiBold"
                                               Text="Weight: — kg"/>
                                    <TextBlock x:Name="BalanceText" Grid.Column="1" Style="{DynamicResource Text.Subtitle}"
                                               Text="Balance: — / —"/>
                                </Grid>
                                <TextBlock x:Name="SensorText" Style="{DynamicResource Text.Mono}" Margin="0,4,0,0"
                                           Text="Sensors: connect to see corner loads"/>
                                <TextBlock x:Name="BoardButtonText" Style="{DynamicResource Text.Subtitle}" Margin="0,4,0,0"
                                           Text="Board button: —"/>
                                <TextBlock x:Name="VJoyAxesText" Style="{DynamicResource Text.Mono}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Profiles -->
            <TabItem Header="Profiles" Style="{StaticResource TabItem.Main}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <Border x:Name="DetailLevelCard" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="SETTINGS DETAIL" Style="{DynamicResource Text.Section}"/>
                                <ComboBox x:Name="DetailLevelCombo" Margin="0,8,0,4"
                                          SelectionChanged="DetailLevelCombo_SelectionChanged"
                                          ToolTip="How much of the settings panel to show."/>
                                <TextBlock x:Name="DetailLevelDescription" Style="{DynamicResource Text.Subtitle}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ProfileCard" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="PROFILE" Style="{DynamicResource Text.Section}"/>
                                <ComboBox x:Name="ProfileCombo" Margin="0,0,0,8" SelectionChanged="ProfileCombo_SelectionChanged"
                                          ToolTip="Output profile — presets configure vJoy and keyboard bindings."/>
                                <TextBlock x:Name="ProfileHintText" Style="{DynamicResource Text.Subtitle}" Margin="0,0,0,8"
                                           Visibility="Collapsed" TextWrapping="Wrap"/>
                                <UniformGrid x:Name="ProfileButtonGrid" Columns="3" Margin="0,0,0,8">
                                    <Button x:Name="GamePresetButton" Content="Games" MinHeight="44" Style="{StaticResource Button.Secondary}" Margin="0,0,4,4" Click="GamePreset_Click"
                                            AutomationProperties.Name="Games profile"
                                            ToolTip="Game controller preset — vJoy left stick for movement."/>
                                    <Button x:Name="MinecraftPresetButton" Content="Minecraft" MinHeight="44" Style="{StaticResource Button.Secondary}" Margin="0,0,4,4" Click="MinecraftPreset_Click"
                                            AutomationProperties.Name="Minecraft profile"
                                            ToolTip="vJoy Device 1 in Controlify: lean = left stick (move), jump = A button."/>
                                    <Button x:Name="DesktopPresetButton" Content="Desktop" MinHeight="44" Style="{StaticResource Button.Secondary}" Margin="0,0,0,4" Click="KeyboardPreset_Click"
                                            AutomationProperties.Name="Desktop keyboard profile"
                                            ToolTip="Keyboard movement preset for desktop use."/>
                                    <Button x:Name="PedalPresetButton" Content="Pedals" MinHeight="44" Style="{StaticResource Button.Secondary}" Margin="0,0,4,0" Click="PedalPreset_Click"
                                            AutomationProperties.Name="Pedals profile"
                                            ToolTip="Pedal-style axis preset."/>
                                    <Button x:Name="MousePresetButton" Content="Mouse" MinHeight="44" Style="{StaticResource Button.Secondary}" Margin="0,0,4,0" Click="MousePreset_Click"
                                            AutomationProperties.Name="Mouse profile"
                                            ToolTip="Balance board controls the mouse cursor."/>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="CustomProfileCard" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="MY PROFILES" Style="{DynamicResource Text.Section}"/>
                                <TextBlock Style="{DynamicResource Text.Subtitle}" TextWrapping="Wrap" Margin="0,4,0,8"
                                           Text="Save your current sliders, bindings, and output settings as a named profile you can reload any time."/>
                                <ComboBox x:Name="CustomProfileCombo" Margin="0,0,0,8"
                                          AutomationProperties.Name="Saved custom profiles"
                                          ToolTip="Your saved custom profiles."/>
                                <UniformGrid Columns="3" Margin="0,0,0,4">
                                    <Button x:Name="SaveProfileButton" Content="Save as…" MinHeight="36"
                                            Style="{StaticResource Button.Primary}" Margin="0,0,4,4" Click="SaveProfileButton_Click"
                                            AutomationProperties.Name="Save current settings as a new profile"
                                            ToolTip="Save the current settings as a new named profile."/>
                                    <Button x:Name="LoadProfileButton" Content="Load" MinHeight="36"
                                            Style="{StaticResource Button.Secondary}" Margin="0,0,4,4" Click="LoadProfileButton_Click"
                                            AutomationProperties.Name="Load selected profile"
                                            ToolTip="Load the selected profile into the current settings."/>
                                    <Button x:Name="DeleteProfileButton" Content="Delete" MinHeight="36"
                                            Style="{StaticResource Button.Secondary}" Margin="0,0,0,4" Click="DeleteProfileButton_Click"
                                            AutomationProperties.Name="Delete selected profile"
                                            ToolTip="Delete the selected profile."/>
                                    <Button x:Name="UpdateProfileButton" Content="Update" MinHeight="36"
                                            Style="{StaticResource Button.Secondary}" Margin="0,0,4,0" Click="UpdateProfileButton_Click"
                                            AutomationProperties.Name="Update selected profile with current settings"
                                            ToolTip="Overwrite the selected profile with the current settings."/>
                                    <Button x:Name="ExportProfileButton" Content="Export…" MinHeight="36"
                                            Style="{StaticResource Button.Secondary}" Margin="0,0,4,0" Click="ExportProfileButton_Click"
                                            AutomationProperties.Name="Export current settings to a file"
                                            ToolTip="Export the current settings to a shareable .json file."/>
                                    <Button x:Name="ImportProfileButton" Content="Import…" MinHeight="36"
                                            Style="{StaticResource Button.Secondary}" Margin="0,0,0,0" Click="ImportProfileButton_Click"
                                            AutomationProperties.Name="Import settings from a file"
                                            ToolTip="Import settings from a .json file and save as a profile."/>
                                </UniformGrid>
                                <TextBlock x:Name="CustomProfileStatusText" Style="{DynamicResource Text.Subtitle}"
                                           TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>
                                <Button x:Name="ResetDefaultsButton" Content="Reset all settings to defaults" MinHeight="32"
                                        HorizontalAlignment="Left" Margin="0,10,0,0" Style="{StaticResource Button.Secondary}"
                                        Click="ResetDefaultsButton_Click"
                                        AutomationProperties.Name="Reset all settings to defaults"
                                        ToolTip="Restore every tuning, binding, and output setting to its default (keeps your paired board)."/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="ThemeCard" Style="{StaticResource Card}">
                            <StackPanel x:Name="ThemeOptionsPanel">
                                <TextBlock Text="APPEARANCE &amp; STARTUP" Style="{DynamicResource Text.Section}"/>
                                <CheckBox x:Name="AutoConnectCheck" Content="Connect automatically on launch" Margin="0,4,0,0"
                                          Checked="SettingChanged" Unchecked="SettingChanged"/>
                                <CheckBox x:Name="StartMinimizedCheck" Content="Start minimized" Margin="0,4,0,0"
                                          ToolTip="Launch minimized to the taskbar (takes effect next launch)."
                                          Checked="SettingChanged" Unchecked="SettingChanged"/>
                                <StackPanel x:Name="ThemeRow" Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Theme" VerticalAlignment="Center" Style="{DynamicResource Text.Subtitle}" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="ThemeCombo" Width="140" SelectionChanged="ThemeCombo_SelectionChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Fine Tuning -->
            <TabItem x:Name="FineTuningTab" Header="Fine Tuning" Style="{StaticResource TabItem.Main}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <Border x:Name="SensitivityCard" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="PRESETS" Style="{DynamicResource Text.Section}"/>
                                <CheckBox x:Name="SimpleSensitivityCheck" Content="Simple presets (kids / accessibility)"
                                          IsChecked="True" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                <WrapPanel x:Name="SimpleSensitivityPanel" Margin="0,8,0,0">
                                    <Button x:Name="SensitivityLowButton" Content="Low" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="SensitivityLow_Click"/>
                                    <Button x:Name="SensitivityMediumButton" Content="Medium" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="SensitivityMedium_Click"/>
                                    <Button x:Name="SensitivityHighButton" Content="High" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="SensitivityHigh_Click"/>
                                    <Button x:Name="SensitivityHighlyButton" Content="Highly sensitive" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="SensitivityHighly_Click"/>
                                    <Button x:Name="SensitivityHairTriggerButton" Content="Hair trigger" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="SensitivityHairTrigger_Click"
                                            ToolTip="Tiny lean sends the stick to full throw — best for micro-adjustments in games."/>
                                </WrapPanel>
                                <StackPanel x:Name="SimpleJumpPanel" Margin="0,12,0,0">
                                    <TextBlock x:Name="SimpleJumpLabel" Text="Jump difficulty" Style="{DynamicResource Text.Subtitle}"/>
                                    <WrapPanel x:Name="SimpleJumpButtonsPanel" Margin="0,6,0,0">
                                        <Button x:Name="JumpEasyButton" Content="Easy to jump" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="JumpEasy_Click"/>
                                        <Button x:Name="JumpNormalButton" Content="Normal jump" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="JumpNormal_Click"/>
                                        <Button x:Name="JumpHardButton" Content="Hard to jump" MinHeight="44" Style="{StaticResource Button.Secondary}" Click="JumpHard_Click"/>
                                    </WrapPanel>
                                </StackPanel>

                                <Border x:Name="FineTuneSection" Margin="0,16,0,0" Padding="0,16,0,0"
                                        BorderBrush="{DynamicResource Brush.CardBorder}" BorderThickness="0,1,0,0">
                                    <StackPanel>
                                        <TextBlock Text="SLIDERS" Style="{DynamicResource Text.Section}"/>
                                        <TextBlock x:Name="FineTuneHintText" Style="{DynamicResource Text.Subtitle}" TextWrapping="Wrap" Margin="0,0,0,8"
                                                   Text="Uncheck “Simple presets” above to show deadzone, sensitivity, triggers, and response curve sliders."/>
                                        <StackPanel x:Name="StandardSensitivityPanel" Visibility="Collapsed" Margin="0,0,0,0">
                                            <CheckBox x:Name="OneFootModeCheck" Content="One-foot mode (high sensitivity + easy jump)"
                                                      Margin="0,0,0,8" Checked="OneFootMode_Changed" Unchecked="OneFootMode_Changed"/>
                                            <TextBlock x:Name="DeadzoneLabel" Style="{DynamicResource Text.Subtitle}"/>
                                            <Slider x:Name="DeadzoneSlider" Minimum="0" Maximum="20" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                            <CheckBox x:Name="SplitAxisDeadzoneCheck" Content="Custom deadzone per axis"
                                                      Margin="0,8,0,0" Checked="SplitAxisDeadzone_Changed" Unchecked="SplitAxisDeadzone_Changed"/>
                                            <StackPanel x:Name="SplitAxisDeadzonePanel" Visibility="Collapsed" Margin="0,4,0,0">
                                                <TextBlock x:Name="DeadzoneLeftRightLabel" Style="{DynamicResource Text.Subtitle}"/>
                                                <Slider x:Name="DeadzoneLeftRightSlider" Minimum="0" Maximum="20" Value="0" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                                <TextBlock x:Name="DeadzoneForwardBackwardLabel" Style="{DynamicResource Text.Subtitle}" Margin="0,8,0,0"/>
                                                <Slider x:Name="DeadzoneForwardBackwardSlider" Minimum="0" Maximum="20" Value="0" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                                <TextBlock Style="{DynamicResource Text.Subtitle}" Margin="0,4,0,0" TextWrapping="Wrap"
                                                           Text="Elliptical deadzone keeps diagonals reachable when axes differ."/>
                                            </StackPanel>
                                            <TextBlock x:Name="SensitivityLabel" Style="{DynamicResource Text.Subtitle}" Margin="0,8,0,0"/>
                                            <Slider x:Name="SensitivitySlider" Minimum="0.5" Maximum="25" Value="1" TickFrequency="0.5" ValueChanged="SettingChanged"/>
                                            <CheckBox x:Name="LockLeftRightAxisCheck" Content="Forward / backward only (lock left–right stick)"
                                                      Margin="0,10,0,0" Checked="AxisLock_Changed" Unchecked="AxisLock_Changed"/>
                                            <CheckBox x:Name="LockForwardBackwardAxisCheck" Content="Left / right only (lock forward–back stick)"
                                                      Margin="0,4,0,0" Checked="AxisLock_Changed" Unchecked="AxisLock_Changed"/>
                                            <CheckBox x:Name="SplitAxisSensitivityCheck" Content="Split axis sensitivity"
                                                      Margin="0,10,0,0" Checked="SplitAxisSensitivity_Changed" Unchecked="SplitAxisSensitivity_Changed"/>
                                            <StackPanel x:Name="SplitAxisSensitivityPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                                <TextBlock x:Name="SensitivityLeftRightLabel" Style="{DynamicResource Text.Subtitle}"/>
                                                <Slider x:Name="SensitivityLeftRightSlider" Minimum="0" Maximum="25" Value="0" TickFrequency="0.5" ValueChanged="SettingChanged"/>
                                                <TextBlock x:Name="SensitivityForwardBackwardLabel" Style="{DynamicResource Text.Subtitle}" Margin="0,8,0,0"/>
                                                <Slider x:Name="SensitivityForwardBackwardSlider" Minimum="0" Maximum="25" Value="0" TickFrequency="0.5" ValueChanged="SettingChanged"/>
                                            </StackPanel>
                                            <TextBlock x:Name="JumpThresholdLabel" Style="{DynamicResource Text.Subtitle}" Margin="0,8,0,0"/>
                                            <Slider x:Name="JumpThresholdSlider" Minimum="0.2" Maximum="80" Value="1" TickFrequency="0.5" ValueChanged="SettingChanged"/>
                                            <StackPanel x:Name="InvertPanel" Margin="0,8,0,0">
                                                <CheckBox x:Name="InvertXCheck" Content="Invert X" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                                <CheckBox x:Name="InvertYCheck" Content="Invert Y" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel x:Name="AdvancedSensitivityPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                            <TextBlock x:Name="TriggerLeftRightLabel" Style="{DynamicResource Text.Subtitle}"/>
                                            <Slider x:Name="TriggerLeftRightSlider" Minimum="1" Maximum="30" Value="8" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                            <TextBlock x:Name="TriggerForwardBackwardLabel" Style="{DynamicResource Text.Subtitle}"/>
                                            <Slider x:Name="TriggerForwardBackwardSlider" Minimum="1" Maximum="30" Value="9" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                            <TextBlock x:Name="JumpHoldLabel" Style="{DynamicResource Text.Subtitle}" Margin="0,8,0,0"/>
                                            <Slider x:Name="JumpHoldSlider" Minimum="0.5" Maximum="4" Value="2" TickFrequency="0.1" ValueChanged="SettingChanged"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                <TextBlock Text="Response curve" VerticalAlignment="Center" Style="{DynamicResource Text.Subtitle}" Margin="0,0,8,0"/>
                                                <ComboBox x:Name="ResponseCurveCombo" Width="180" SelectionChanged="ResponseCurveCombo_SelectionChanged"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced -->
            <TabItem x:Name="AdvancedTab" Header="Advanced" Style="{StaticResource TabItem.Main}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <Border x:Name="KeyboardSection" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="KEYBOARD &amp; MOUSE" Style="{DynamicResource Text.Section}"/>
                                <TextBlock Style="{DynamicResource Text.Subtitle}" TextWrapping="Wrap" Margin="0,0,0,8"
                                           Text="Map lean directions to keys or mouse actions. Disable vJoy keyboard block to use these while gaming."/>
                                <controls:ActionBindingRow x:Name="BindLeft" SlotDisplayName="Left" BindingChanged="ActionBinding_Changed"/>
                                <controls:ActionBindingRow x:Name="BindRight" SlotDisplayName="Right" BindingChanged="ActionBinding_Changed"/>
                                <controls:ActionBindingRow x:Name="BindForward" SlotDisplayName="Forward" BindingChanged="ActionBinding_Changed"/>
                                <controls:ActionBindingRow x:Name="BindBackward" SlotDisplayName="Backward" BindingChanged="ActionBinding_Changed"/>
                                <controls:ActionBindingRow x:Name="BindJump" SlotDisplayName="Jump" BindingChanged="ActionBinding_Changed"/>
                                <controls:ActionBindingRow x:Name="BindModifier" SlotDisplayName="Modifier" BindingChanged="ActionBinding_Changed"/>
                                <controls:ActionBindingRow x:Name="BindDiagonalLeft" SlotDisplayName="Diagonal left" BindingChanged="ActionBinding_Changed"/>
                                <controls:ActionBindingRow x:Name="BindDiagonalRight" SlotDisplayName="Diagonal right" BindingChanged="ActionBinding_Changed"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="VJoySection" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="CONTROLLER OUTPUT (VJOY)" Style="{DynamicResource Text.Section}"/>
                                <CheckBox x:Name="EnableVJoyCheck" Content="Use virtual game controller" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                <CheckBox x:Name="SendCgCheck" Content="Balance → X/Y axes" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                <CheckBox x:Name="SendSensorsCheck" Content="Load sensors → Z/RX/RY/RZ" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                <CheckBox x:Name="DisableActionsCheck" Content="Disable keyboard/mouse output" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="vJoy device" VerticalAlignment="Center" Style="{DynamicResource Text.Subtitle}" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="VJoyDeviceCombo" Width="64" SelectionChanged="SettingChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border x:Name="CalibrationSection" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="CALIBRATION" Style="{DynamicResource Text.Section}"/>
                                <TextBlock Style="{DynamicResource Text.Subtitle}" TextWrapping="Wrap"
                                           Text="Tare zeros the board while you are off it. Set center while standing in your neutral pose."/>
                                <CheckBox x:Name="AutoTareCheck" Content="Auto-tare when connected" Margin="0,8,0,0" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="PerformanceSection" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="PERFORMANCE" Style="{DynamicResource Text.Section}"/>
                                <TextBlock x:Name="PollIntervalLabel" Style="{DynamicResource Text.Subtitle}" Margin="0,4,0,0"/>
                                <Slider x:Name="PollIntervalSlider" Minimum="10" Maximum="100" Value="50"
                                        TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"
                                        AutomationProperties.Name="Board update interval in milliseconds"/>
                                <TextBlock Style="{DynamicResource Text.Subtitle}" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Lower = more responsive but more CPU. 50 ms (20 Hz) matches the board's native rate."/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="DiagnosticsSection" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="DIAGNOSTICS" Style="{DynamicResource Text.Section}"/>
                                <TextBlock x:Name="HealthSummaryText" Style="{DynamicResource Text.Subtitle}" Margin="0,0,0,8"
                                           Text="Run a health check to verify vJoy and Bluetooth."/>
                                <TextBlock x:Name="VJoyStatusText" Style="{DynamicResource Text.Mono}" Margin="0,0,0,8"/>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button x:Name="RunHealthCheckButton" Content="Health check" Style="{StaticResource Button.Primary}" Click="RunHealthCheckButton_Click"/>
                                    <Button Content="Copy report" Style="{StaticResource Button.Secondary}" Click="CopyReportButton_Click"/>
                                    <Button Content="Open logs" Style="{StaticResource Button.Secondary}" Click="OpenLogFolderButton_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Live session log (collapsible, pinned) -->
        <Border x:Name="LiveLogPanel" Grid.Row="2" Style="{StaticResource Card}" Margin="0,8,0,0" Padding="12,8,12,8">
            <Expander x:Name="SessionLogExpander" Background="Transparent" BorderThickness="0"
                      Expanded="SessionLogExpander_Changed" Collapsed="SessionLogExpander_Changed">
                <Expander.Header>
                    <DockPanel LastChildFill="True">
                        <TextBlock Text="SESSION LOG" Style="{DynamicResource Text.Section}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LogPreviewText" DockPanel.Dock="Left" Margin="12,0,0,0"
                                   Style="{DynamicResource Text.Mono}" FontSize="11" Opacity="0.75"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   Visibility="Collapsed"/>
                    </DockPanel>
                </Expander.Header>
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="140"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                        <Button Content="Clear view" Style="{StaticResource Button.Ghost}" DockPanel.Dock="Right"
                                Click="ClearLogViewButton_Click"/>
                        <Button Content="Open logs folder" Style="{StaticResource Button.Ghost}" DockPanel.Dock="Right" Margin="0,0,8,0"
                                Click="OpenLogFolderButton_Click"/>
                    </DockPanel>
                    <TextBox x:Name="LogBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                             FontFamily="{StaticResource Font.Mono}" FontSize="12"
                             Background="{DynamicResource Brush.Card}"
                             Foreground="{DynamicResource Brush.Foreground}"
                             BorderBrush="{DynamicResource Brush.CardBorder}" BorderThickness="1"/>
                </Grid>
            </Expander>
        </Border>
    </Grid>
</Window>
