<Window x:Class="BalanceBoard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BalanceBoard.App.Controls"
        Title="Balance Board Controller"
        Height="820" Width="1180"
        MinHeight="680" MinWidth="960">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Balance Board Controller" Style="{StaticResource HeroTitle}"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Border x:Name="ConnectionPill" Style="{StaticResource StatusPill}">
                        <TextBlock x:Name="ConnectionPillText" Text="Disconnected" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    </Border>
                    <Border x:Name="VJoyPill" Style="{StaticResource StatusPill}" Margin="8,0,0,0">
                        <TextBlock x:Name="VJoyPillText" Text="vJoy: checking…" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="StatusText" Margin="0,8,0,0" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="SetupButton" Content="Setup Wizard" Style="{StaticResource SecondaryButton}" Click="SetupButton_Click"/>
                <Button x:Name="ConnectButton" Content="Connect" Click="ConnectButton_Click"/>
                <Button x:Name="DisconnectButton" Content="Disconnect" Style="{StaticResource GhostButton}" Click="DisconnectButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Tabs -->
        <TabControl Grid.Row="1">
            <TabItem Header="Dashboard">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="LIVE BALANCE" Style="{StaticResource SectionTitle}"/>
                                <TextBlock x:Name="DirectionText" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            </StackPanel>
                            <controls:BalanceBoardVisual x:Name="BoardVisual" Margin="0,36,0,48"/>
                            <StackPanel VerticalAlignment="Bottom">
                                <TextBlock x:Name="WeightText" FontWeight="SemiBold"/>
                                <TextBlock x:Name="BalanceText" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="CONTROLLER OUTPUT" Style="{StaticResource SectionTitle}"/>
                                    <CheckBox x:Name="EnableVJoyCheck" Content="Use game controller (vJoy)" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="SendCgCheck" Content="Map balance to X/Y axes" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="SendSensorsCheck" Content="Map load sensors to Z/RX/RY/RZ" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="DisableActionsCheck" Content="Game controller only (no keyboard/mouse)" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="vJoy device" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextMutedBrush}"/>
                                        <ComboBox x:Name="VJoyDeviceCombo" Width="72" SelectionChanged="SettingChanged"/>
                                    </StackPanel>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Button Content="Game Controller" Click="GamePreset_Click"/>
                                        <Button Content="Pedal Preset" Style="{StaticResource SecondaryButton}" Click="PedalPreset_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="CALIBRATION" Style="{StaticResource SectionTitle}"/>
                                    <WrapPanel>
                                        <Button Content="Tare" Click="Tare_Click"/>
                                        <Button Content="Set Center" Style="{StaticResource SecondaryButton}" Click="SetCenter_Click"/>
                                        <Button Content="Reset Center" Style="{StaticResource GhostButton}" Click="ResetCenter_Click"/>
                                    </WrapPanel>
                                    <CheckBox x:Name="AutoTareCheck" Content="Auto-tare on connect" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="SENSITIVITY" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="DeadzoneLabel" Foreground="{StaticResource TextMutedBrush}"/>
                                    <Slider x:Name="DeadzoneSlider" Minimum="0" Maximum="20" Value="5" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SettingChanged"/>
                                    <TextBlock x:Name="SensitivityLabel" Foreground="{StaticResource TextMutedBrush}"/>
                                    <Slider x:Name="SensitivitySlider" Minimum="0.5" Maximum="2" Value="1" TickFrequency="0.1" ValueChanged="SettingChanged"/>
                                    <CheckBox x:Name="InvertXCheck" Content="Invert X" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                    <CheckBox x:Name="InvertYCheck" Content="Invert Y" Checked="SettingChanged" Unchecked="SettingChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Debug Suite">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource Card}" Grid.Row="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="DEBUG SUITE" Style="{StaticResource SectionTitle}"/>
                                <TextBlock x:Name="HealthSummaryText" Text="Run a health check to verify vJoy, Bluetooth, and drivers." TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                <Button x:Name="RunHealthCheckButton" Content="Run Health Check" Click="RunHealthCheckButton_Click"/>
                                <Button Content="Copy Report" Style="{StaticResource SecondaryButton}" Click="CopyReportButton_Click"/>
                                <Button Content="Open Log Folder" Style="{StaticResource SecondaryButton}" Click="OpenLogFolderButton_Click"/>
                                <Button Content="Clear View" Style="{StaticResource GhostButton}" Click="ClearLogViewButton_Click"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.4*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="SYSTEM STATUS" Style="{StaticResource SectionTitle}"/>
                                <TextBlock x:Name="VJoyStatusText" TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}" FontSize="12"/>
                                <TextBlock Text="SENSOR SNAPSHOT" Style="{StaticResource SectionTitle}" Margin="0,16,0,8"/>
                                <TextBlock x:Name="SensorText" TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="SESSION LOG" Style="{StaticResource SectionTitle}"/>
                                <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" BorderThickness="0" Background="Transparent"/>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
