<Window x:Class="BalanceBoard.App.Dialogs.NamePromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save profile"
        Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Background}">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" Text="Profile name" TextWrapping="Wrap"
                   Style="{DynamicResource Text.Body}" Margin="0,0,0,8"/>
        <TextBox x:Name="InputBox" MinHeight="30" VerticalContentAlignment="Center"
                 KeyDown="InputBox_KeyDown"/>
        <TextBlock x:Name="ErrorText" Foreground="{DynamicResource Brush.Warning}"
                   Style="{DynamicResource Text.Subtitle}" TextWrapping="Wrap"
                   Visibility="Collapsed" Margin="0,6,0,0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="Save" MinWidth="88" MinHeight="32"
                    Style="{StaticResource Button.Primary}" Margin="0,0,8,0" Click="OkButton_Click"/>
            <Button x:Name="CancelButton" Content="Cancel" MinWidth="88" MinHeight="32"
                    Style="{StaticResource Button.Secondary}" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
