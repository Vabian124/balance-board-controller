<Window x:Class="BalanceBoard.App.Dialogs.DevicePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose balance board"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Background}">
    <StackPanel Margin="16">
        <TextBlock Text="Multiple balance boards were found. Pick which one to use:"
                   TextWrapping="Wrap" Style="{DynamicResource Text.Body}" Margin="0,0,0,12"/>
        <ListBox x:Name="DeviceList" MinHeight="120" MaxHeight="240"
                 MouseDoubleClick="DeviceList_MouseDoubleClick"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="Connect" MinWidth="88" MinHeight="32"
                    Style="{StaticResource Button.Primary}" Margin="0,0,8,0" Click="OkButton_Click"
                    IsDefault="True"/>
            <Button Content="Cancel" MinWidth="88" MinHeight="32"
                    Style="{StaticResource Button.Secondary}" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
